# OpenAI-compatible API settings
AI_AGENT_API_KEY=your_api_key_here
AI_AGENT_MODEL=gpt-4o-mini
AI_AGENT_BASE_URL=https://api.openai.com/v1

# Runtime settings
AI_AGENT_TEMPERATURE=0.2
AI_AGENT_MAX_TOOL_ROUNDS=4

# TLS/SSL settings
AI_AGENT_SSL_VERIFY=true
# AI_AGENT_CA_BUNDLE=/absolute/path/to/ca-bundle.pem

# Logging settings
AI_AGENT_LOG_ENABLED=false
AI_AGENT_LOG_STAGES=input,prompt,output,usage,tools,errors
# AI_AGENT_LOG_FILE=./logs/agent.log

# Optional GitHub API token for higher rate limits and private repos you can access
# GITHUB_TOKEN=ghp_...

# Optional system prompt override
AI_AGENT_SYSTEM_PROMPT=You are a practical CLI AI agent for repository analysis and planning. Use github_repo_info for GitHub repository facts and plan_optimizer for time allocation problems. Format structured answers in Markdown: use tables for comparisons, bullet lists for plans, and bold text for key conclusions. Keep responses concise and cite tool results when relevant.
