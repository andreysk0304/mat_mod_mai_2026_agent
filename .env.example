# Настройки API, совместимого с OpenAI
AI_AGENT_API_KEY=your_api_key_here
AI_AGENT_MODEL=gpt-4o-mini
AI_AGENT_BASE_URL=https://api.openai.com/v1

# Настройки выполнения
AI_AGENT_TEMPERATURE=0.2
AI_AGENT_MAX_TOOL_ROUNDS=4

# Настройки TLS/SSL
AI_AGENT_SSL_VERIFY=true
# AI_AGENT_CA_BUNDLE=/absolute/path/to/ca-bundle.pem

# Настройки логирования
AI_AGENT_LOG_ENABLED=false
AI_AGENT_LOG_STAGES=input,prompt,output,usage,tools,errors
# AI_AGENT_LOG_FILE=./logs/agent.log

# Необязательный токен GitHub API для большего лимита запросов и доступных приватных репозиториев
# GITHUB_TOKEN=ghp_...

# Необязательная замена системного промпта
AI_AGENT_SYSTEM_PROMPT=Ты практичный консольный AI-агент для анализа репозиториев и планирования. Используй github_repo_info для фактов о GitHub-репозиториях и plan_optimizer для задач распределения времени. Форматируй структурированные ответы в Markdown: используй таблицы для сравнений, списки для планов и жирный текст для ключевых выводов. Отвечай кратко и ссылайся на результаты инструментов, когда это уместно.
